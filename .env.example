# Hotel Price Intelligence - Environment Variables

# ============================================
# OPTIONAL: Google Hotels / Serper API
# ============================================
# For Google Hotels integration, get a free API key from:
# https://serper.dev (free tier: 100 requests/month)
# 
# This provides fallback pricing data when primary scrapers fail
SERPER_API_KEY=your_serper_api_key_here

# ============================================
# Scraping Configuration
# ============================================
# Maximum timeout for each scraper (in milliseconds)
SCRAPE_TIMEOUT_MS=35000

# Number of hotels to fetch per scraper
SCRAPE_LIMIT=50

# Enable/disable specific scrapers
ENABLE_BOOKING_SCRAPER=true
ENABLE_AGODA_SCRAPER=true
ENABLE_MAKEMYTRIP_SCRAPER=true
ENABLE_EXPEDIA_SCRAPER=true
ENABLE_GOOGLE_SCRAPER=true

# ============================================
# Caching (Optional - for production)
# ============================================
# Redis caching for search results
# REDIS_URL=redis://...
# CACHE_TTL_SECONDS=300

# ============================================
# Monitoring & Logging
# ============================================
# Enable verbose logging
DEBUG_LOGGING=true

# Sentry for error tracking (optional)
# SENTRY_DSN=your_sentry_dsn

# ============================================
# Next.js
# ============================================
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
